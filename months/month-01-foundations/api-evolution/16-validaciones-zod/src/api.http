# ==================================================================
# GUIDE TO EXECUTE THESE TESTS
# ==================================================================
#
# 1. REQUIREMENT: You need the "REST Client" extension in VS Code
#    (Search for the extension created by "Huachao Mao" and install it)
#
# 2. SERVER: Ensure your API is running
#    Open your terminal in the project folder (month-01-foundations) and execute:
#    > npm run dev:16
#
# 3. USAGE: Once the server is running, you will see a small
#    "Send Request" button above each URL block
#    Click there to test the response in the right panel
# ==================================================================

### 1. SUCCESSFUL TEST: A valid dish
# Should return status 201 and the success message
POST http://localhost:3000/menu
Content-Type: application/json

{
  "name": "Milanesa Napolitana",
  "price": 8500,
  "category": "Main Course",
  "available": true
}

### 2. ERROR TEST: Negative price and short name
# Zod should throw errors on "name" and "price" (Status 400)
POST http://localhost:3000/menu
Content-Type: application/json

{
  "name": "A", 
  "price": -500,
  "category": "Appetizer"
}

### 3. ERROR TEST: Invalid category
# The "Breakfast" category is not in your allowed enum list (Status 400)
POST http://localhost:3000/menu
Content-Type: application/json

{
  "name": "Cafe con Leche",
  "price": 2000,
  "category": "Breakfast"
}